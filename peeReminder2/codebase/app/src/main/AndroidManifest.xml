<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <!-- Notification permission (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Full-screen intent permission (Android 10+) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    
    <!-- Exact alarm permission (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    
    <!-- Phone state permission (for detecting active phone calls) -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    
    <!-- Wake lock permission (for reliable alarm delivery) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- Foreground service permission (Android 14+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    
    <!-- Boot completed permission (for alarm recovery after device reboot) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PeeReminder2">
        
        <!-- Main Activity - Entry point of the application -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PeeReminder2">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- AlarmActivity - Full-screen alarm display when reminder triggers -->
        <activity
            android:name=".ui.AlarmActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:showWhenLocked="true"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:theme="@style/Theme.PeeReminder2">
        </activity>
        
        <!-- ReminderReceiver - Handles alarm triggers from AlarmManager -->
        <receiver
            android:name=".data.notification.ReminderReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.logact.peereminder2.ACTION_REMINDER" />
                <action android:name="com.logact.peereminder2.ACTION_RETRY" />
            </intent-filter>
        </receiver>
        
        <!-- BootReceiver - Reschedules alarms after device reboot -->
        <receiver
            android:name=".data.notification.BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        
        <!-- AcknowledgeReceiver - Handles acknowledgment action from notification -->
        <receiver
            android:name=".data.notification.AcknowledgeReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.logact.peereminder2.ACTION_ACKNOWLEDGE" />
            </intent-filter>
        </receiver>
        
    </application>

</manifest>